SERVICE_NAME=friendservice
SERVICE_PORT=8082
APP_ENV=prod
APP_VERSION=1.0.0

NEO4J_URI=neo4j://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

USER_SERVICE_BASE_URL=http://localhost:8081
JWT_SECRET=secretkey

LOG_LEVEL=info
LOG_FORMAT=json
LOG_OUTPUT=file
LOG_FILE_PATH=logs/app.log
LOG_ERROR_FILE_PATH=logs/error.log
LOG_MAX_SIZE_MB=20
LOG_MAX_BACKUPS=10
LOG_MAX_AGE_DAYS=30
LOG_COMPRESS=true
